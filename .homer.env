# HomerTrakker runtime configuration (.homer.env)
# Loaded by scripts/homerctl.sh on start. Edit values and run ./scripts/homerctl.sh restart

HOMER_PAUSE=0
HOMER_AUTO_UPLOAD=1
HOMER_BROADCAST_MAX_SECS=15
HOMER_TOTAL_MAX_SECS=30
HOMER_REQUIRE_BOTH=1
HOMER_NOTIFY_PHONE=+19144142424

# Timeout in seconds to wait for both clips before falling back to broadcast-only
HOMER_FALLBACK_TIMEOUT=45
